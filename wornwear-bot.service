# ── systemd service unit for Worn Wear Bot ────────────────────────────────────
# This keeps the bot running forever on a Linux VPS.
# If it crashes, systemd restarts it automatically.
#
# IMPORTANT: This template is for reference only.
# Follow the instructions in digitalocean-deployment-guide.md Step 8 for the
# correct configuration based on your user (root or ubuntu).
#
# SETUP:
#   1. Copy this file to /etc/systemd/system/wornwear-bot.service
#   2. Replace the entire content with the correct config from the deployment guide
#   3. sudo systemctl daemon-reload
#   4. sudo systemctl enable wornwear-bot   # start on boot
#   5. sudo systemctl start wornwear-bot    # start now
#
# USEFUL COMMANDS:
#   systemctl status wornwear-bot           # check if running
#   journalctl -u wornwear-bot -f           # live logs
#   systemctl stop wornwear-bot             # stop it
#   systemctl restart wornwear-bot          # restart it
#
# ───────────────────────────────────────────────────────────────────────────────
# FOR ROOT USER:
# ───────────────────────────────────────────────────────────────────────────────

[Unit]
Description=Worn Wear Monitor Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/wornwear-bot
ExecStart=/root/.local/bin/uv run python bot.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target

