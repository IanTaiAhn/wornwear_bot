# ── Worn Wear Bot Configuration ───────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The bot reads settings from here so you never have to edit bot.py directly.

# Keywords to match — ALL must be present in the product title (comma separated)
# Example: "synchilla,medium,blue" only matches if all three appear
KEYWORDS=synchilla,fleece,medium

# Poll interval range in seconds (bot picks a random value each cycle)
POLL_MIN=30
POLL_MAX=65

# Set to "true" to automatically click Add to Cart when a match is found.
# Set to "false" to only get notified (safer default).
AUTO_ADD_CART=false

# Push notification URL (optional but recommended).
# Sign up free at ntfy.sh, pick a unique topic name, and paste the URL here.
# e.g. https://ntfy.sh/my-wornwear-alerts-abc123
NOTIFY_URL=
