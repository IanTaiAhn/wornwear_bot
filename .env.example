# ── Worn Wear Bot Configuration ───────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The bot reads settings from here so you never have to edit bot.py directly.

# ── Keywords & Style Numbers ──────────────────────────────────────────────────
# Keywords to match — ALL must be present in the product title (comma separated)
# Example: "synchilla,medium,blue" only matches if all three appear
KEYWORDS=synchilla,fleece,medium

# Style numbers to match — ANY number matches (comma separated, optional)
# Style numbers are the 5-digit codes in product URLs (e.g., _25528_)
STYLE_NUMBERS=25528,25527

# ── Polling ───────────────────────────────────────────────────────────────────
# Poll interval range in seconds (bot picks a random value each cycle)
POLL_MIN=30
POLL_MAX=65

# ── Cart Behavior ─────────────────────────────────────────────────────────────
# Set to "true" to automatically bag items when a match is found (30-min hold)
# Set to "false" to only get notified without adding to cart
AUTO_ADD_CART=true

# ── Notifications ─────────────────────────────────────────────────────────────
# Push notification URL (required for alerts)
# Sign up free at ntfy.sh, pick a unique topic name, and paste the URL here
# e.g. https://ntfy.sh/my-wornwear-alerts-abc123
NOTIFY_URL=

# ── noVNC Remote Browser (Production/Droplet Only) ────────────────────────────
# Set USE_VNC=true on your droplet to enable remote browser access via noVNC
# Leave as false for local testing (runs in headless mode)
USE_VNC=false

# Your DigitalOcean droplet IP address (used in notification links)
# Leave empty for local testing
DROPLET_IP=
